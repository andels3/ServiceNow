<script><![CDATA[(function executeRule(current, previous /*null when async*/) {

	var attSysId = current.sys_id;

	var grUser = new GlideRecord("sys_user");
	grUser.addQuery("photo", attSysId);
	grUser.query();
	while (grUser.next()) {
		grUser.photo = "";
		grUser.update();
	}

	var grLive = new GlideRecord("live_profile");
	grLive.addQuery("photo", attSysId);
	grLive.query();
	while (grLive.next()){
		grLive.photo = "";
		grLive.update();
	}

	GlideCacheManager.flush("user_avatar_cache");

})(current, previous);]]></script>
