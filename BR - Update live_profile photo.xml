<script><![CDATA[(function executeRule(current, previous /*null when async*/) {

	var gr = new GlideRecord('live_profile');
	gr.addQuery('document', current.sys_id);
	gr.query();

	while (gr.next()){
		GlideCacheManager.flush("user_avatar_cache"); // forces user avatars to sync to new photos
		gr.photo = current.photo;
		gr.update();
	}

})(current, previous);]]></script>
